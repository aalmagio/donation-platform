# ============================================
# Donation Platform - Environment (esempio)
# ============================================
# Copia questo file in `.env` e compila i valori.
# IL FILE .env NON VA MAI COMMITTATO SU GIT.

# Applicazione
APP_ENV=production
# Codice del form/istanza: deve corrispondere alla colonna `Form` della tabella `config`
LP=DEFAULT

# Database MySQL/MariaDB
DB_IP=localhost
DB_USER=
DB_PASSWORD=
DB_DBNAME=donazioni

# IP autorizzati alle operazioni di amministrazione (separati da virgola)
AUTHORIZED_IPS=127.0.0.1

# --- Identità organizzazione (white label) ---
# Questi valori possono essere sovrascritti dalla tabella `config` (che ha priorità)
ORG_NAME="La tua Organizzazione"
ORG_EMAIL=info@example.org
ORG_NOREPLY=noreply@example.org
ORG_PRIVACY_EMAIL=privacy@example.org
ORG_WEBSITE=https://www.example.org
ORG_PRIVACY_URL=/privacy/

# Email del super-amministratore del backend (be/)
SUPERADMIN_EMAIL=

# --- Gateway di pagamento ---
# Attiva/disattiva i gateway nella tabella `config` (USE_PAYPAL, USE_SATISPAY, USE_GESTPAY, USE_STRIPE)
USE_SANDBOX=true

# Satispay: JSON con public_key, private_key e key_id generati in fase di onboarding
# (vedi https://developers.satispay.com/)
SY_AUTH_SANDBOX=
SY_AUTH_PRODUCTION=
